<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>eh</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Urbanist:wght@400;500;700&family=Noto+Sans+SC:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        * { box-sizing: border-box; }
        body {
            background-color: #0f172a;
            color: #f5f5f5;
            margin: 0;
            padding: 20px 0;
            display: grid;
            place-items: center;
            font-family: 'Urbanist', 'Noto Sans SC', sans-serif;
            min-height: 100vh;
        }

        .dashboard-container {
            width: 1280px;
            background-color: #000;
            border-radius: 12px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
            padding: 40px 60px;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        /* 顶部进度条：用于指示后台网络请求状态 */
        #network-loader {
            position: absolute;
            top: 0;
            left: 0;
            height: 3px;
            background: #deff9a;
            width: 0%;
            transition: width 0.2s ease, opacity 0.3s ease;
            opacity: 0;
            border-top-left-radius: 12px;
            border-top-right-radius: 12px;
        }

        .title {
            font-size: 42px;
            font-weight: 700;
            margin: 0 0 40px 0;
            letter-spacing: 1px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .title span { color: #deff9a; }
        .status-indicator { font-size: 14px; font-weight: 400; color: #64748b; }

        .layout-grid { display: grid; grid-template-columns: 1fr 1.5fr; gap: 40px; }
        .progress-panel { display: flex; flex-direction: column; gap: 24px; }
        
        .card {
            background: #1e293b;
            border-radius: 16px;
            padding: 24px;
            border: 1px solid rgba(222, 255, 154, 0.1);
        }

        .metric-row { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 16px; }
        .metric-name { font-size: 16px; color: #94a3b8; }
        .metric-val { font-size: 32px; font-weight: 700; color: #deff9a; line-height: 1; transition: all 0.3s; }
        
        .bar-bg { height: 10px; background: #0f172a; border-radius: 5px; overflow: hidden; margin-bottom: 8px; }
        .bar-fill { height: 100%; background: #deff9a; width: 0%; transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1); }
        .metric-sub { display: flex; justify-content: space-between; font-size: 14px; color: #64748b; }

        .controls-panel { display: flex; flex-direction: column; gap: 24px; }
        .btn-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }

        .action-btn {
            background: #334155;
            border: 1px solid transparent;
            border-radius: 12px;
            padding: 24px 16px;
            cursor: pointer;
            color: #f5f5f5;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
            transition: all 0.2s ease;
        }
        .action-btn:disabled { opacity: 0.5; cursor: not-allowed; }
        .action-btn i { font-size: 28px; }
        .action-btn span { font-size: 16px; font-weight: 700; }
        
        .action-btn:hover:not(:disabled) { background: #475569; }
        .action-btn.active {
            background: rgba(222, 255, 154, 0.1);
            border-color: #deff9a;
            color: #deff9a;
            box-shadow: 0 0 15px rgba(222, 255, 154, 0.15);
        }

        .stop-btn {
            padding: 16px;
            background: #ef4444;
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            display: none;
            text-align: center;
            transition: background 0.2s;
        }
        .stop-btn:hover { background: #dc2626; }
        .stop-btn:disabled { opacity: 0.5; cursor: not-allowed; }

        .dom-chart-card {
            background: #1e293b;
            border-radius: 16px;
            padding: 24px;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        .dom-chart-title { color: #94a3b8; font-size: 14px; margin-bottom: 20px; text-align: center; }

        .stacked-bar { display: flex; height: 24px; width: 100%; border-radius: 12px; overflow: hidden; background: #0f172a; }
        .segment { height: 100%; transition: width 0.5s ease; position: relative; }
        .segment:hover::after {
            content: attr(data-tooltip); position: absolute; bottom: 120%; left: 50%;
            transform: translateX(-50%); background: #000; padding: 6px 12px;
            border-radius: 4px; font-size: 12px; white-space: nowrap; z-index: 10; pointer-events: none;
        }

        .legend-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(100px, 1fr)); gap: 16px; margin-top: 24px; }
        .legend-item { display: flex; align-items: center; gap: 8px; font-size: 14px; color: #cbd5e1; }
        .legend-color { width: 12px; height: 12px; border-radius: 3px; }

        #django-context { display: none; }
        
        /* 交互反馈动画 */
        @keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.6; } 100% { opacity: 1; } }
        .is-loading { animation: pulse 1.5s infinite; pointer-events: none; }
    </style>
</head>
<body>

<div class="dashboard-container">
    <div id="network-loader"></div>
    <h1 class="title">
        <div>Academic <span>Analytics</span></div>
        <div class="status-indicator" id="system-status">系统就绪</div>
    </h1>

    <div class="layout-grid">
        <div class="progress-panel">
            <div class="card">
                <div class="metric-row">
                    <span class="metric-name">今日有效时间</span>
                    <span class="metric-val" id="today-val">0h</span>
                </div>
                <div class="bar-bg"><div class="bar-fill" id="today-bar"></div></div>
                <div class="metric-sub">
                    <span>目标: 6.0h / 日</span>
                    <span id="today-pct" style="color:#deff9a;">0%</span>
                </div>
            </div>

            <div class="card">
                <div class="metric-row">
                    <span class="metric-name">本周有效时间 (基于周日)</span>
                    <span class="metric-val" id="week-val">0h</span>
                </div>
                <div class="bar-bg"><div class="bar-fill" id="week-bar"></div></div>
                <div class="metric-sub">
                    <span>目标: 42.0h / 周</span>
                    <span id="week-pct" style="color:#deff9a;">0%</span>
                </div>
            </div>
        </div>

        <div class="controls-panel">
            <div class="btn-grid">
                <button class="action-btn" id="btn-math" onclick="triggerAction('start', 'math')">
                    <i class="fa-solid fa-calculator"></i><span>数学</span>
                </button>
                <button class="action-btn" id="btn-english" onclick="triggerAction('start', 'english')">
                    <i class="fa-solid fa-language"></i><span>外语</span>
                </button>
                <button class="action-btn" id="btn-major" onclick="triggerAction('start', 'major')">
                    <i class="fa-solid fa-book-bookmark"></i><span>专业</span>
                </button>
            </div>

            <button class="stop-btn" id="btn-stop" onclick="triggerAction('stop')">
                <i class="fa-solid fa-stop"></i> 结算当前任务
            </button>

            <div class="dom-chart-card">
                <div class="dom-chart-title">各科时间配置比例</div>
                <div class="stacked-bar" id="dom-stacked-bar"></div>
                <div class="legend-grid" id="dom-legend"></div>
            </div>
	    <div style="margin-top: 20px;">
    		<button class="action-btn" onclick="setAuthToken()">eh专用</button>
	    </div>
        </div>
    </div>
</div>

<div id="django-context">
    <span id="data-chart">{{ chart_data|safe }}</span>
    <span id="data-active">{{ active_category }}</span>
    <span id="data-daily">{{ daily_stats|safe }}</span>
    <span id="data-today">{{ today_str }}</span>
</div>

<script>
    const TARGET_DAY_MINUTES = 360; 
    const TARGET_WEEK_MINUTES = 2520;

    function setAuthToken() {
    const token = prompt("符咒交出来");
    if (token) {
        localStorage.setItem('auth_token', token);
        alert("不是成龙");
    }
}


    function getCsrfToken() {
        const cookies = document.cookie.split(';');
        for (let i = 0; i < cookies.length; i++) {
            const cookie = cookies[i].trim();
            if (cookie.startsWith('csrftoken=')) return decodeURIComponent(cookie.substring('csrftoken='.length));
        }
        return '';
    }

    function setNetworkState(isActive, msg = "") {
        const loader = document.getElementById('network-loader');
        const statusText = document.getElementById('system-status');
        const buttons = document.querySelectorAll('.action-btn, .stop-btn');
        
        if (isActive) {
            loader.style.opacity = '1';
            loader.style.width = '50%';
            statusText.innerText = '同步中...';
            buttons.forEach(b => b.disabled = true);
            document.body.classList.add('is-loading');
        } else {
            loader.style.width = '100%';
            statusText.innerText = msg || '系统就绪';
            setTimeout(() => { loader.style.opacity = '0'; loader.style.width = '0%'; }, 500);
            buttons.forEach(b => b.disabled = false);
            document.body.classList.remove('is-loading');
        }
    }

    // [核心优化] 异步获取服务器最新状态，局部替换 DOM
    async function softReloadDashboard() {
        try {
            const response = await fetch(window.location.href);
            const htmlText = await response.text();
            
            // 解析返回的 HTML 字符串
            const parser = new DOMParser();
            const doc = parser.parseFromString(htmlText, 'text/html');
            
            // 提取新的数据载荷
            document.getElementById('data-chart').innerText = doc.getElementById('data-chart').innerText;
            document.getElementById('data-active').innerText = doc.getElementById('data-active').innerText;
            document.getElementById('data-daily').innerText = doc.getElementById('data-daily').innerText;
            document.getElementById('data-today').innerText = doc.getElementById('data-today').innerText;

            // 重新初始化视图引擎
            initViewEngine();
        } catch (error) {
            console.error("无刷新重载失败:", error);
            window.location.reload(); // 降级处理：若局部解析失败，执行强制刷新
        }
    }

    async function triggerAction(action, category = null) {
	const myToken = localStorage.getItem('auth_token');

        setNetworkState(true);
        try {
            const res = await fetch('/api/action/', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-CSRFToken': getCsrfToken() ,'Authorization': myToken },
                body: JSON.stringify({ action: action, category: category })
            });
            const data = await res.json();
            
            if (data.status === 'success') {
                // 不再触发 location.reload()，而是执行局部重载
                await softReloadDashboard();
                setNetworkState(false, data.msg.includes('结算') ? `更新成功: ${data.msg}` : '任务已启动');
            } else {
                alert("nmsl");
                if (data.msg.includes('作废') || data.msg.includes('无活动')) {
                    await softReloadDashboard(); // 如果任务超时被后端清理，同步前端状态
                }
                setNetworkState(false, '操作中止');
            }
        } catch(error) {
            alert("网络通讯故障，请检查连接");
            setNetworkState(false, '离线状态');
        }
    }

    // 视图渲染引擎
    function initViewEngine() {
        // 1. 解析数据
        const ctx = {
            chartData: JSON.parse(document.getElementById('data-chart').innerText || '[]'),
            activeCat: document.getElementById('data-active').innerText || 'None',
            dailyStats: JSON.parse(document.getElementById('data-daily').innerText || '{}'),
            todayStr: document.getElementById('data-today').innerText || new Date().toISOString().split('T')[0]
        };

        // 2. 清理历史 UI 状态
        document.querySelectorAll('.action-btn').forEach(btn => btn.classList.remove('active'));
        document.getElementById('btn-stop').style.display = 'none';

        // 3. 注入新的 UI 状态
        if (ctx.activeCat !== 'None' && ctx.activeCat.trim() !== '') {
            const btn = document.getElementById(`btn-${ctx.activeCat}`);
            if(btn) btn.classList.add('active');
            document.getElementById('btn-stop').style.display = 'block';
        }

        // 4. 执行计算与图表重绘
        calculateProgress(ctx);
        renderDomChart(ctx.chartData);
    }

    function calculateProgress(ctx) {
        const todayMin = ctx.dailyStats[ctx.todayStr] || 0;
        updateProgressUI('today', todayMin, TARGET_DAY_MINUTES);

        const todayObj = new Date(ctx.todayStr);
        const dayOfWeek = todayObj.getDay(); 
        
        let weekTotal = 0;
        for (let i = 0; i <= dayOfWeek; i++) {
            const cursorDate = new Date(todayObj);
            cursorDate.setDate(todayObj.getDate() - i);
            const isoString = cursorDate.toISOString().split('T')[0];
            weekTotal += (ctx.dailyStats[isoString] || 0);
        }
        updateProgressUI('week', weekTotal, TARGET_WEEK_MINUTES);
    }

    function updateProgressUI(idPrefix, currentMin, targetMin) {
        const hours = (currentMin / 60).toFixed(2);
        const ratio = Math.min(100, (currentMin / targetMin * 100));
        document.getElementById(`${idPrefix}-val`).innerText = `${hours}h`;
        document.getElementById(`${idPrefix}-bar`).style.width = `${ratio.toFixed(1)}%`;
        document.getElementById(`${idPrefix}-pct`).innerText = `${ratio.toFixed(1)}%`;
    }

    function renderDomChart(chartData) {
        const barContainer = document.getElementById('dom-stacked-bar');
        const legendContainer = document.getElementById('dom-legend');
        const totalMinutes = chartData.reduce((sum, item) => sum + item.value, 0);
        
        if (totalMinutes === 0) {
            barContainer.innerHTML = '<div style="width:100%;text-align:center;line-height:24px;color:#64748b;font-size:12px;">暂无数据</div>';
            legendContainer.innerHTML = '';
            return;
        }

        const palette = ['#deff9a', '#86efac', '#34d399', '#38bdf8', '#818cf8'];
        let barHtml = '', legendHtml = '';

        chartData.forEach((item, index) => {
            const pct = (item.value / totalMinutes * 100).toFixed(2);
            const color = palette[index % palette.length];
            const hours = (item.value / 60).toFixed(1);

            barHtml += `<div class="segment" style="width: ${pct}%; background-color: ${color};" data-tooltip="${item.name}: ${hours}h (${pct}%)"></div>`;
            legendHtml += `<div class="legend-item"><div class="legend-color" style="background-color: ${color};"></div><span>${item.name} <strong style="color:#fff;margin-left:4px">${hours}h</strong></span></div>`;
        });

        barContainer.innerHTML = barHtml;
        legendContainer.innerHTML = legendHtml;
    }

    window.addEventListener('DOMContentLoaded', initViewEngine);
</script>
</body>
</html>
